# ============================================================
# KOStockCrewAI 환경변수 예시 파일
# ------------------------------------------------------------
# 1) 이 파일을 복사해서 ".env" 파일을 만드세요.
#    (Windows 명령:  copy .env.example .env)
# 2) 아래 각 값에 본인의 실제 API Key를 입력하세요.
# 3) ".env" 파일은 절대로 GitHub 등에 올리지 마세요.
# ============================================================

# --- OpenAI (GPT 투자 브리프 / 임베딩) ---
OPENAI_API_KEY=sk-proj-your_openai_key_here

# --- DART (전자공시 재무정보) ---
DART_API_KEY=your_dart_key_here

# --- ECOS (한국은행 거시지표) ---
ECOS_API_KEY=your_ecos_key_here

# --- 코스콤 (OHLCV / 수급) ---
KOSCOM_API_KEY=your_koscom_key_here
KOSCOM_BASE_URL=https://your-koscom-api-base-url
# 인증 방식: bearer 또는 x-api-key
KOSCOM_AUTH_TYPE=bearer

# --- PostgreSQL 데이터베이스 ---
# 로컬 실행 기준. Docker compose 사용 시 README 참고(host를 postgres 로 변경).
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/kostockcrewai

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456789:your_telegram_bot_token
TELEGRAM_CHAT_ID=123456789

# --- 리포트 저장 폴더 ---
REPORT_DIR=reports

# --- ECOS 통계표/항목 코드 (기준금리 예시) ---
# 실제 운영 전에 ECOS 사이트에서 코드가 맞는지 반드시 확인하세요.
ECOS_BASE_RATE_STAT_CODE=722Y001
ECOS_BASE_RATE_ITEM_CODE=0101000
